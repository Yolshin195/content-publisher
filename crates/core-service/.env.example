DATABASE_URL=postgres://postgres:postgres@localhost:5432/core_db

SCHEDULER_TICK_INTERVAL_SECONDS=30
PUBLISH_MAX_ATTEMPTS=3

# Реестр Publisher-микросервисов. Пока реализован только Telegram (следующий этап);
# без этой переменной публикация в Telegram будет возвращать понятную ошибку gateway,
# остальной функционал (CRUD, календарь) работает без неё.
PUBLISHER_TELEGRAM_URL=http://localhost:8081
# PUBLISHER_VK_URL=http://localhost:8082

# Не обязательно: без Media Service статьи создаются без картинки, запрос
# presigned URL будет возвращать понятную ошибку вместо падения сервиса.
# MEDIA_SERVICE_URL=http://localhost:8090

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info,core_service=debug,tower_http=info
